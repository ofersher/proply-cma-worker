# proply-cma-worker — environment
PORT=8080

# Bearer secret the Vercel CMA job sends as `Authorization: Bearer <secret>`.
# Required before /comparables works. Generate a long random string.
CMA_WORKER_SECRET=

# Serialized queue — keep at 1 (one warm headed browser, one request at a time).
MAX_CONCURRENCY=1

# Gentle pacing between deal-data fetches (ms). Spike-validated ~2.5–3s.
FETCH_DELAY_MS=2750

# Cooldown after a failure streak (ms) — repeated rapid loads depress the
# reCAPTCHA score; the spike recovered after ~30s.
COOLDOWN_MS=30000

# Retry-on-miss for the ~60%/attempt SPA flakiness measured in the spike.
MAX_RETRIES=3

# Comparable window.
MONTHS_BACK=12

NADLAN_BASE_URL=https://www.nadlan.gov.il
LOG_LEVEL=info
